# ═══════════════════════════════════════════════════════════════════════
# Cipher — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env && chmod 600 .env
# ═══════════════════════════════════════════════════════════════════════

# === LLM Provider ===
LLM_PROVIDER=openrouter                  # "openrouter" or "anthropic"
ANTHROPIC_API_KEY=                        # Anthropic API key (required if LLM_PROVIDER=anthropic)
OPENROUTER_API_KEY=                       # OpenRouter API key (required if LLM_PROVIDER=openrouter)

# === LLM Models ===
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6   # Main conversation model (Sonnet)
BACKGROUND_MODEL=anthropic/claude-haiku-4-5     # Background tasks model (Haiku)
CONVERSATION_MODEL=anthropic/claude-haiku-4-5   # Conversation routing model (currently unused)
OPUS_MODEL=anthropic/claude-opus-4-6            # Self-inspection model (Opus)

# === Telegram ===
TELEGRAM_BOT_TOKEN=                       # Bot token from @BotFather
TELEGRAM_ALLOWED_ID=0                     # Telegram user ID allowed to interact

# === Server ===
SERVER_PORT=5000                          # Flask server port (default: 5000)
CIPHER_API_TOKEN=                         # API auth token for Flask endpoints (empty = auth disabled)
CIPHER_SERVER_URL=http://127.0.0.1:5000   # Server URL (used by cipher_bot.py)

# === ElevenLabs TTS ===
ELEVENLABS_API_KEY=                       # ElevenLabs API key for text-to-speech
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb # ElevenLabs voice ID

# === WhatsApp (Green API) ===
GREEN_API_INSTANCE_ID=                    # Green API instance ID
GREEN_API_TOKEN=                          # Green API token

# === Google OAuth2 ===
GOOGLE_CREDENTIALS_FILE=secrets/credentials.json  # Path to Google OAuth2 credentials
GOOGLE_TOKEN_FILE=secrets/token.json               # Path to Google OAuth2 token (auto-generated)

# === Voice / STT ===
INPUT_MODE=both                           # "text", "voice", or "both"
VOSK_MODEL_PATH=models/vosk-model-it-0.22       # Path to Vosk Italian model
VOSK_WAKE_MODEL_PATH=models/vosk-model-en-us-0.22  # Path to Vosk English model (wake words)
WAKE_WORD=cipher                          # Primary wake word
WAKE_WORDS=cipher,jarvis,ehi,ci sei,ehi amico   # All wake words (comma-separated)
LANGUAGE=it                               # Language code
MIC_DEVICE_INDEX=-1                       # Microphone device index (-1 = default)
SILENCE_TIMEOUT=2.0                       # Seconds of silence before stopping recording

# === User ===
BIRTHDAY_DAY=0                            # User birthday day (0 = not set)
BIRTHDAY_MONTH=0                          # User birthday month (0 = not set)

# === Feature Flags ===
CONSCIOUSNESS_ENABLED=true                # Enable/disable autonomous consciousness loop

# === Weather (optional) ===
WEATHER_CITY=Rome                         # City for weather context
